rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    /**
     * Play Billing 영수증 검증을 통과한 사용자에게 박힌 custom claim.
     * 현재 룰에서는 강제하지 않지만, 운영에서 paid-only read 가 필요한 컬렉션이 생기면
     * 여기서 분기하면 된다. 실제 결제 enforcement 는 서버 라우트의 requirePaidUser 에 위임.
     */
    function isPaid() {
      return isAuthenticated() && request.auth.token.paid == true;
    }

    // ── users ──
    // 본인만 read/write. 채팅·초대 시절 처음보는 uid 의 프로필을 읽어야 했던 요건은 사라졌다.
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);

      // 본인 일일 체크리스트/회고 (홈 대시보드, 문서 ID = YYYY-MM-DD KST)
      match /dailyEntries/{ymd} {
        allow read, write: if isOwner(uid);
      }

      // 본인 매일 동기부여 카드 (배경화면용, 문서 ID = YYYY-MM-DD KST)
      // 생성·갱신은 서버(Admin SDK, /api/daily-motivation)에서 수행하지만
      // 클라이언트가 onSnapshot 으로 즉시 구독할 수 있도록 본인 read 를 허용.
      match /dailyMotivations/{ymd} {
        allow read: if isOwner(uid);
        // 클라이언트 직접 write 는 막고, 서버(Admin SDK)에서만 갱신.
        allow write: if false;
      }

      // 본인 일별 호출 한도 카운터 (server-only write).
      // 클라이언트가 카운터를 조작하지 못하도록 write 는 차단하고 read 만 허용.
      match /usage/{ymd} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // 본인 정체성 진행도 (라벨당 누적 응답 수 + 최근 응답).
      // 카운터/리스트 조작을 막기 위해 클라이언트 write 는 막고 서버(Admin SDK)에서만 갱신.
      // 홈에서 onSnapshot 으로 즉시 표시할 수 있도록 본인 read 는 허용.
      match /identityProgress/{identityTag} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // "성공한 나의 모습" 다짐 따라쓰기 일별 로그 (문서 ID = YYYY-MM-DD KST).
      // 서버 트랜잭션에서만 기록. 클라는 read 로 오늘 체크인 여부만 즉시 확인.
      match /affirmationLogs/{ymd} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    // ── entitlements ──
    // 결제 영수증 검증 결과 영구 저장. /api/entitlement/verify 가 Admin SDK 로 기록.
    // 클라이언트 직접 write 는 절대 금지 (paid 위장 차단).
    // 본인은 결제 상태/시점을 read 가능 (UI 에서 "결제 완료" 표시 등).
    match /entitlements/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // ── famousQuotes ──
    // 안드로이드 위젯/메인 앱에 노출할 큐레이션 명언 풀.
    // 위젯/홈 카드는 서버 라우트(Admin SDK)를 통해 가져가지만, 추후 클라이언트 직접 조회가
    // 필요할 수 있어 로그인 사용자에게 read 만 열어둔다. 쓰기는 어드민/Admin SDK 전용.
    match /famousQuotes/{quoteId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── tokenUsage ──
    // LLM 호출당 토큰/비용 기록 (server-only).
    match /tokenUsage/{docId} {
      allow read, write: if false;
    }

    // 명시적으로 정의되지 않은 경로는 모두 차단 (deny-by-default).
    // 새 컬렉션을 추가할 때는 반드시 위에 명시적 룰을 추가할 것.
  }
}
