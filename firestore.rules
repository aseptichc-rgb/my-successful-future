rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 로그인한 사용자만 접근 가능
    function isAuthenticated() {
      return request.auth != null;
    }

    // 본인 확인
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // 세션 참여자 여부 (sessionId 문서 get() 1회)
    // 사용처: messages, autoNewsConfigs, keywordAlerts, pushTokens 등
    // 쿼리는 반드시 sessionId 필터가 선행되어야 per-doc 검증이 동작한다.
    function isSessionParticipant(sessionId) {
      return isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/sessions/$(sessionId)).data.participants;
    }

    // ── users ──
    // 초대 시 이메일로 상대 uid 조회가 필요하여 read 는 전체 로그인 사용자에 열어둔다.
    // 민감/개인 데이터는 절대 users 문서 루트에 저장하지 않고, 하위 서브컬렉션(본인만)에 둔다.
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);

      // ── 본인 페르소나별 기억 샤드 ──
      match /personaMemories/{personaId} {
        allow read, write: if isOwner(uid);
      }

      // ── 본인 커스텀 페르소나 ──
      match /customPersonas/{personaId} {
        allow read, write: if isOwner(uid);
      }

      // ── 본인 페르소나(빌트인/커스텀) 정시 뉴스 스케줄 ──
      // 크론(Admin SDK)도 collectionGroup 으로 스캔하지만 Admin SDK 는 룰을 우회한다.
      match /personaSchedules/{personaId} {
        allow read, write: if isOwner(uid);
      }

      // ── 본인 빌트인 페르소나 오버라이드 (이름/아이콘/설명/프롬프트 커스터마이징) ──
      match /personaOverrides/{personaId} {
        allow read, write: if isOwner(uid);
      }

      // ── 본인 일일 체크리스트/회고 (홈 대시보드, 문서 ID = YYYY-MM-DD KST) ──
      match /dailyEntries/{ymd} {
        allow read, write: if isOwner(uid);
      }

      // ── 본인 매일 동기부여 카드 (배경화면용, 문서 ID = YYYY-MM-DD KST) ──
      // 생성·갱신은 서버(Admin SDK, /api/daily-motivation) 에서 수행하지만
      // 클라이언트가 onSnapshot 으로 즉시 구독할 수 있도록 본인 read/write 를 허용.
      match /dailyMotivations/{ymd} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── sessions ──
    // 참여자(participants 배열)만 읽기/수정/삭제 가능.
    // create 시에도 본인이 participants 에 반드시 포함되어야 한다.
    match /sessions/{sessionId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow delete: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
    }

    // ── messages ──
    // 세션 참여자만 해당 세션 메시지 read/create/delete 가능.
    // sessionId 는 문서에 비정규화돼 있어 sessions 문서 get() 한 번으로 참여자 검증.
    match /messages/{messageId} {
      allow read: if isSessionParticipant(resource.data.sessionId);
      allow create: if isSessionParticipant(request.resource.data.sessionId);
      allow delete: if isSessionParticipant(resource.data.sessionId);
    }

    // ── invitations ──
    // 당사자(발신자·수신자)만 읽기. 발신 시 fromUid == 요청자 강제(남의 이름 사칭 방지).
    match /invitations/{invitationId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.fromUid;
      allow update: if isAuthenticated()
        && request.auth.uid == resource.data.toUid;
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.toUid;
    }

    // ── inviteLinks ──
    // 토큰 기반 조회가 필요하므로 read 는 로그인 사용자 전체에 열어둔다
    // (토큰 자체가 난수이므로 노출되어도 소유 증명 없이는 의미 없음).
    // create 시 fromUid == 요청자 강제.
    match /inviteLinks/{linkId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.fromUid;
    }

    // ── presence ──
    match /presence/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid);
    }

    // ── fcmTokens ──
    match /fcmTokens/{tokenId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.uid;
    }

    // ── autoNewsConfigs ──
    // 문서 ID == sessionId. 세션 참여자만 읽기/쓰기.
    match /autoNewsConfigs/{sessionId} {
      allow read, write: if isSessionParticipant(sessionId);
    }

    // ── keywordAlerts ──
    // 문서 ID == sessionId. 세션 참여자만 읽기/쓰기.
    match /keywordAlerts/{sessionId} {
      allow read, write: if isSessionParticipant(sessionId);
    }

    // ── pushTokens ──
    // 외부 푸시용 토큰: 평문 토큰을 저장하지 않으며, 모든 쓰기는 서버(Admin SDK) 전용.
    // 세션 참여자만 메타데이터 읽기 가능.
    match /pushTokens/{tokenId} {
      allow read: if isSessionParticipant(resource.data.sessionId);
      allow create, update, delete: if false; // 서버에서만 처리
    }

    // ── sessionDocuments ──
    // 첨부 문서: 세션 참여자만 읽기 가능. 생성은 서버(Admin SDK)에서만.
    // 토글/삭제는 세션 참여자(토글) 또는 본인(삭제) — API 라우트에서 추가 검증.
    match /sessionDocuments/{docId} {
      // participants 는 업로드 시 세션에서 비정규화된 배열. cross-doc get() 을 피하면
      // onSnapshot 쿼리에서 권한 평가가 안정적이고 SDK INTERNAL ASSERTION 캐스케이드도 차단.
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow create: if false; // 클라이언트 직접 생성 금지 (Admin SDK 만)
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.ownerUid;
    }

    // ── userReferenceDocs ──
    // 사용자별 Google Docs 참조 링크. 모든 읽기/쓰기는 서버(Admin SDK) 를 통해 처리되며
    // 클라이언트 직접 접근은 차단한다. (API: /api/reference-docs)
    match /userReferenceDocs/{docId} {
      allow read, write: if false;
    }

    // ── dailyRitualConfigs ──
    // 데일리 리추얼(아침 브리프 / 저녁 회고) 설정 (문서 ID = uid)
    match /dailyRitualConfigs/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── tokenUsage ──
    // LLM 호출당 토큰/비용 기록 (server-only). 어드민 통계는 Admin SDK 경유로만 조회.
    match /tokenUsage/{docId} {
      allow read, write: if false;
    }

    // ── personaNews ──
    // 페르소나가 자동 수집한 기사들 (server-only write).
    // 모든 로그인 사용자는 토론 UI에서 페르소나의 수집 기사 헤드라인을 볼 수 있다.
    match /personaNews/{personaId}/items/{articleId} {
      allow read: if isAuthenticated();
      allow write: if false; // 크론(Admin SDK)에서만 쓰기
    }

    // ── personaNewsSchedule ──
    // 페르소나별 일일 수집 스케줄 (server-only write). 클라이언트 노출 불필요.
    match /personaNewsSchedule/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // ── famousQuotes ──
    // 안드로이드 위젯/메인 앱에 노출할 큐레이션 명언 풀.
    // 모든 로그인 사용자 read 가능 (위젯이 본인 인증 토큰으로 호출). 쓰기는 Admin SDK 전용.
    match /famousQuotes/{quoteId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── publicPersonas ──
    // 사용자가 자신의 customPersona 를 "공개"로 토글하면 이 컬렉션에 미러링된다.
    // 모든 로그인 사용자가 둘러보고 자신의 customPersonas 로 복제할 수 있다.
    // 작성자(creatorUid) 본인만 생성/수정/삭제 가능.
    match /publicPersonas/{personaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.creatorUid;
      allow update: if isAuthenticated()
        && request.auth.uid == resource.data.creatorUid
        && request.auth.uid == request.resource.data.creatorUid;
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.creatorUid;
    }
  }
}
