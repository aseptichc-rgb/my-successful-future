rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 로그인한 사용자만 접근 가능
    function isAuthenticated() {
      return request.auth != null;
    }

    // 본인 확인
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ── users ──
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);

      // ── 본인 목표 서브컬렉션 ──
      match /goals/{goalId} {
        allow read, write: if isOwner(uid);
      }

      // ── 본인 데일리 체크리스트 ──
      match /dailyTasks/{taskId} {
        allow read, write: if isOwner(uid);
      }

      // ── 본인 페르소나별 기억 샤드 ──
      match /personaMemories/{personaId} {
        allow read, write: if isOwner(uid);
      }

      // ── 본인 커스텀 페르소나 ──
      match /customPersonas/{personaId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── sessions ──
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow delete: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
    }

    // ── messages ──
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── invitations ──
    match /invitations/{invitationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && request.auth.uid == resource.data.toUid;
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.toUid;
    }

    // ── inviteLinks ──
    match /inviteLinks/{linkId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // ── presence ──
    match /presence/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid);
    }

    // ── fcmTokens ──
    match /fcmTokens/{tokenId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.uid;
    }

    // ── autoNewsConfigs ──
    // 문서 ID가 sessionId와 동일하므로 해당 세션 참가자만 읽기/쓰기 가능
    match /autoNewsConfigs/{sessionId} {
      allow read, write: if isAuthenticated();
    }

    // ── keywordAlerts ──
    // 사용자가 직접 등록한 키워드 기반 알림 설정 (문서 ID = sessionId)
    match /keywordAlerts/{sessionId} {
      allow read, write: if isAuthenticated();
    }

    // ── pushTokens ──
    // 외부 푸시용 토큰: 평문 토큰을 저장하지 않으며, 모든 쓰기는 서버(Admin SDK) 전용.
    // 클라이언트는 메타데이터(label, expiresAt 등)만 읽을 수 있고 tokenHash 도 함께 들어가지만
    // 해시이므로 노출돼도 평문 복원 불가. 다만 발급자 또는 세션 참여자만 읽도록 제한.
    match /pushTokens/{tokenId} {
      allow read: if isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/sessions/$(resource.data.sessionId)).data.participants;
      allow create, update, delete: if false; // 서버에서만 처리
    }

    // ── sessionDocuments ──
    // 첨부 문서: 세션 참여자만 읽기 가능. 생성은 서버(Admin SDK)에서만.
    // 토글/삭제는 세션 참여자(토글) 또는 본인(삭제) — API 라우트에서 추가 검증.
    match /sessionDocuments/{docId} {
      // participants 는 업로드 시 세션에서 비정규화된 배열. cross-doc get() 을 피하면
      // onSnapshot 쿼리에서 권한 평가가 안정적이고 SDK INTERNAL ASSERTION 캐스케이드도 차단.
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow create: if false; // 클라이언트 직접 생성 금지 (Admin SDK 만)
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.ownerUid;
    }

    // ── userReferenceDocs ──
    // 사용자별 Google Docs 참조 링크. 모든 읽기/쓰기는 서버(Admin SDK) 를 통해 처리되며
    // 클라이언트 직접 접근은 차단한다. (API: /api/reference-docs)
    match /userReferenceDocs/{docId} {
      allow read, write: if false;
    }

    // ── dailyRitualConfigs ──
    // 데일리 리추얼(아침 브리프 / 저녁 회고) 설정 (문서 ID = uid)
    match /dailyRitualConfigs/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── personaNews ──
    // 페르소나가 자동 수집한 기사들 (server-only write).
    // 모든 로그인 사용자는 토론 UI에서 페르소나의 수집 기사 헤드라인을 볼 수 있다.
    match /personaNews/{personaId}/items/{articleId} {
      allow read: if isAuthenticated();
      allow write: if false; // 크론(Admin SDK)에서만 쓰기
    }

    // ── personaNewsSchedule ──
    // 페르소나별 일일 수집 스케줄 (server-only write). 클라이언트 노출 불필요.
    match /personaNewsSchedule/{docId} {
      allow read: if false;
      allow write: if false;
    }
  }
}
